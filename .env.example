# Rename this file to .env for local testing.
# DO NOT share these values with anyone.

ANGEL_API_KEY=your_angelone_api_key
ANGEL_CLIENT_CODE=your_client_code
ANGEL_PASSWORD=your_pin_or_password
ANGEL_TOTP_SECRET=your_totp_secret

# Optional security for your Custom GPT Action
RIGA_ACTION_TOKEN=change-this-secret-token
